    "strict_file_locks": true
  },
  "mcps": {
    "context7": true,
    "grep_app": true,
    "web_agent_mcp": true,
    "pg_mcp": true,
    "ssh_mcp": true,
    "openai_image_gen_mcp": true,
    "searxng": true,
    "mariadb": true
  },
  "agents": {}
}
