{
  "set_default_agent": true,
  "hooks": {
    "profile": "standard",
    "comment_guard": true,
    "session_start": true,
    "pre_tool_use": true,
    "task_tracking": true,
    "compaction": true,
    "session_end": true
  },
  "workflow": {
