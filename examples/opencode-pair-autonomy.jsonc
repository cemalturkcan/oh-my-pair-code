{
  "default_mode": "coordinator",
  "set_default_agent": true,
  "hooks": {
    "intent_gate": false,
    "todo_continuation": true,
    "comment_guard": true,
    "flush_queued_prompts": true,
    "todo_continuation_cooldown_ms": 30000
  },
  "mcps": {
    "context7": true,
    "grep_app": true,
    "chrome_devtools": true,
    "pg_mcp": true,
    "ssh_mcp": true,
    "sudo_mcp": true,
    "searxng": true
  },
  "agents": {
    "ryo": {
      "variant": "high"
    },
    "shounen-bat": {
      "model": "kimi-for-coding/k2p5"
    },
    "eiri": {
      "model": "kimi-for-coding/k2p5"
    },
    "bondrewd": {
      "model": "kimi-for-coding/k2p5"
    }
  }
}
