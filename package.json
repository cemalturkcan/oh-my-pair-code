{
  "name": "opencode-pair-autonomy",
  "version": "0.1.0",
  "description": "Lean OpenCode harness plugin with pair and autonomous modes, curated MCPs, and skill-aware prompts.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "opencode-pair-autonomy": "bin/opencode-pair-autonomy.js"
  },
  "files": [
    "dist",
    "bin",
    "vendor",
    "examples",
    "README.md"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --format esm && bun build src/cli.ts --outdir dist --target bun --format esm && tsc --emitDeclarationOnly",
    "clean": "rm -rf dist",
    "prepare": "bun run build",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "opencode",
    "plugin",
    "agent",
    "pair-programming",
    "autonomous"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Opencode-DCP/opencode-pair-autonomy.git"
  },
  "license": "MIT",
  "dependencies": {
    "@opencode-ai/plugin": "latest",
    "jsonc-parser": "^3.3.1",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "bun-types": "1.3.6",
    "typescript": "^5.7.3"
  }
}
